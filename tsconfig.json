{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "CommonJS",
    "lib":              ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop":  true,
    "strict":           true,
    "skipLibCheck":     true,
    "outDir":           ".vercel/output"
  },
  "include": ["api/**/*.ts"]
}
